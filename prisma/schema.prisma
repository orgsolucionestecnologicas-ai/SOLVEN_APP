generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SalePaymentType {
  CASH
  CREDIT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  TWO_FOR_ONE
  THREE_FOR_TWO
  MINIMUM_PURCHASE
  SPECIAL_PRICE
  BUNDLED_PRODUCTS
}

enum PromotionApplication {
  ALL_PRODUCTS
  CATEGORY
  SPECIFIC_PRODUCT
  BUNDLED
}

enum PromotionActivation {
  AUTOMATIC
  MANUAL_CODE
  BOTH
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum UserRole {
  OWNER
  CASHIER
  INVENTORY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Tenant {
  id                String              @id @default(cuid())
  businessName      String
  email             String              @unique
  plan              String              @default("trial")
  trialEndsAt       DateTime?
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  users             User[]
  products          Product[]
  sales             Sale[]
  customers         Customer[]
  expenses          Expense[]
  cashMovements     CashMovement[]
  cashRegisterSessions CashRegisterSession[]
  debts             Debt[]
  debtPayments      DebtPayment[]
  categories        Category[]
  services          Service[]
  promotions        Promotion[]
  inventoryMovements InventoryMovement[]
  storeSettings     StoreSettings?
  subscription      Subscription?
  helpQueries       HelpQuery[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("")
  role      UserRole @default(OWNER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Product {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  name               String
  productCode        String?             @unique
  categoryName       String              @default("Otros")
  costPrice          Decimal             @db.Decimal(12, 2)
  salePrice          Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  categoryId         String?
  subcategoryId      String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  subcategory        Subcategory?        @relation(fields: [subcategoryId], references: [id])
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([tenantId])
  @@index([categoryId])
  @@index([subcategoryId])
}

model Sale {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  saleDate        DateTime         @default(now())
  paymentType     SalePaymentType  @default(CASH)
  customerId      String?
  debtId          String?          @unique
  totalAmount     Decimal          @db.Decimal(12, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(10, 2)
  customer        Customer?        @relation(fields: [customerId], references: [id])
  debt            Debt?            @relation(fields: [debtId], references: [id])
  items           SaleItem[]
  promotionUsages PromotionUsage[]
  returns         Return[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  productId  String?
  serviceId  String?
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  sale       Sale     @relation(fields: [saleId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
  service    Service? @relation(fields: [serviceId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
  @@index([serviceId])
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  expenseDate DateTime @default(now())
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  phone        String?
  email        String?
  customerCode String?  @unique
  debts        Debt[]
  sales        Sale[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model Debt {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  customerId      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  remainingAmount Decimal       @db.Decimal(12, 2)
  customer        Customer      @relation(fields: [customerId], references: [id])
  sale            Sale?
  payments        DebtPayment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model DebtPayment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  debtId      String
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @default(now())
  debt        Debt     @relation(fields: [debtId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([debtId])
}

model CashMovement {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  movementDate DateTime @default(now())
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  source       String
  referenceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([source, referenceId])
}

model Promotion {
  id                          String               @id @default(cuid())
  tenantId                    String
  tenant                      Tenant               @relation(fields: [tenantId], references: [id])
  name                        String
  code                        String?
  type                        PromotionType
  discountValue               Decimal              @db.Decimal(10, 2)
  application                 PromotionApplication
  categoryName                String?
  productAId                  String?
  productBId                  String?
  productBDiscount            Decimal?             @db.Decimal(10, 2)
  minimumAmount               Decimal?             @db.Decimal(10, 2)
  fixedPrice                  Decimal?             @db.Decimal(10, 2)
  activationType              PromotionActivation
  minimumPurchaseDiscountType String?              @default("PERCENTAGE")
  startsAt                    DateTime
  endsAt                      DateTime
  daysOfWeek                  String?
  maxUsages                   Int?
  maxUsagesPerCustomer        Int?
  isActive                    Boolean              @default(true)
  usages                      PromotionUsage[]
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  @@index([tenantId])
}

model PromotionUsage {
  id             String    @id @default(cuid())
  promotionId    String
  promotion      Promotion @relation(fields: [promotionId], references: [id])
  saleId         String?
  sale           Sale?     @relation(fields: [saleId], references: [id])
  customerId     String?
  discountAmount Decimal   @db.Decimal(10, 2)
  appliedAt      DateTime  @default(now())

  @@index([promotionId])
  @@index([saleId])
}

model CashRegisterSession {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  status           CashRegisterStatus @default(OPEN)
  cashierName      String
  branchName       String             @default("Tienda Principal")
  shift            String?
  openedAt         DateTime           @default(now())
  closedAt         DateTime?
  openingAmount    Decimal            @db.Decimal(10, 2)
  closingAmount    Decimal?           @db.Decimal(10, 2)
  expectedAmount   Decimal?           @db.Decimal(10, 2)
  difference       Decimal?           @db.Decimal(10, 2)
  openingNotes     String?
  closingNotes     String?
  openingBreakdown Json?
  closingBreakdown Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId])
}

model InventoryMovement {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  productId      String
  movementDate   DateTime @default(now())
  reason         String
  previousStock  Int
  newStock       Int
  quantityChange Int
  product        Product  @relation(fields: [productId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([productId])
}

model Category {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  subcategories Subcategory[]
  products      Product[]
  createdAt     DateTime      @default(now())

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Service {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  code        String     @unique
  name        String
  description String?
  price       Decimal    @db.Decimal(10, 2)
  isActive    Boolean    @default(true)
  saleItems   SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
}

model Return {
  id          String       @id @default(cuid())
  saleId      String
  sale        Sale         @relation(fields: [saleId], references: [id])
  items       ReturnItem[]
  totalAmount Decimal      @db.Decimal(12, 2)
  createdAt   DateTime     @default(now())

  @@index([saleId])
}

model ReturnItem {
  id        String @id @default(cuid())
  returnId  String
  return    Return @relation(fields: [returnId], references: [id])
  productId String
  quantity  Int

  @@index([returnId])
}

model CodeCounter {
  id      String @id
  lastVal Int    @default(0)
}

model StoreSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  businessName         String   @default("SOLVEN")
  ownerName            String   @default("Propietario")
  phone                String   @default("")
  email                String   @default("")
  address              String   @default("")
  taxId                String   @default("")
  currency             String   @default("ARS")
  timezone             String   @default("America/Argentina/Buenos_Aires")
  dateFormat           String   @default("DD/MM/YYYY")
  language             String   @default("es")
  printerEnabled       Boolean  @default(false)
  soundsEnabled        Boolean  @default(true)
  darkMode             Boolean  @default(false)
  desktopNotifications Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  rebillSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}


model HelpQuery {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}
