generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SalePaymentType {
  CASH
  CREDIT
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  TWO_FOR_ONE
  THREE_FOR_TWO
  MINIMUM_PURCHASE
  SPECIAL_PRICE
  BUNDLED_PRODUCTS
}

enum PromotionApplication {
  ALL_PRODUCTS
  CATEGORY
  SPECIFIC_PRODUCT
  BUNDLED
}

enum PromotionActivation {
  AUTOMATIC
  MANUAL_CODE
  BOTH
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  costPrice          Decimal             @db.Decimal(12, 2)
  salePrice          Decimal             @db.Decimal(12, 2)
  stock              Int                 @default(0)
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model Sale {
  id              String           @id @default(cuid())
  saleDate        DateTime         @default(now())
  paymentType     SalePaymentType  @default(CASH)
  customerId      String?
  debtId          String?          @unique
  totalAmount     Decimal          @db.Decimal(12, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(10, 2)
  customer        Customer?        @relation(fields: [customerId], references: [id])
  debt            Debt?            @relation(fields: [debtId], references: [id])
  items           SaleItem[]
  promotionUsages PromotionUsage[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([customerId])
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  sale       Sale     @relation(fields: [saleId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
}

model Expense {
  id          String   @id @default(cuid())
  expenseDate DateTime @default(now())
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  debts     Debt[]
  sales     Sale[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Debt {
  id              String        @id @default(cuid())
  customerId      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  remainingAmount Decimal       @db.Decimal(12, 2)
  customer        Customer      @relation(fields: [customerId], references: [id])
  sale            Sale?
  payments        DebtPayment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([customerId])
}

model DebtPayment {
  id          String   @id @default(cuid())
  debtId      String
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @default(now())
  debt        Debt     @relation(fields: [debtId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([debtId])
}

model CashMovement {
  id           String   @id @default(cuid())
  movementDate DateTime @default(now())
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  source       String
  referenceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([source, referenceId])
}

model Promotion {
  id                   String               @id @default(cuid())
  name                 String
  code                 String?              @unique
  type                 PromotionType
  discountValue        Decimal              @db.Decimal(10, 2)
  application          PromotionApplication
  categoryName         String?
  productAId           String?
  productBId           String?
  productBDiscount     Decimal?             @db.Decimal(10, 2)
  minimumAmount        Decimal?             @db.Decimal(10, 2)
  fixedPrice           Decimal?             @db.Decimal(10, 2)
  activationType       PromotionActivation
  startsAt             DateTime
  endsAt               DateTime
  daysOfWeek           String?
  maxUsages            Int?
  maxUsagesPerCustomer Int?
  isActive             Boolean              @default(true)
  usages               PromotionUsage[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model PromotionUsage {
  id             String    @id @default(cuid())
  promotionId    String
  promotion      Promotion @relation(fields: [promotionId], references: [id])
  saleId         String?
  sale           Sale?     @relation(fields: [saleId], references: [id])
  customerId     String?
  discountAmount Decimal   @db.Decimal(10, 2)
  appliedAt      DateTime  @default(now())

  @@index([promotionId])
  @@index([saleId])
}

model InventoryMovement {
  id             String   @id @default(cuid())
  productId      String
  movementDate   DateTime @default(now())
  reason         String
  previousStock  Int
  newStock       Int
  quantityChange Int
  product        Product  @relation(fields: [productId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([productId])
}
