generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SalePaymentType {
  CASH
  CREDIT
  MIXED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  TWO_FOR_ONE
  THREE_FOR_TWO
  MINIMUM_PURCHASE
  SPECIAL_PRICE
  BUNDLED_PRODUCTS
}

enum PromotionApplication {
  ALL_PRODUCTS
  CATEGORY
  SPECIFIC_PRODUCT
  BUNDLED
}

enum PromotionActivation {
  AUTOMATIC
  MANUAL_CODE
  BOTH
}

enum CustomerSegment {
  NINGUNO
  NUEVO
  RECURRENTE
  VIP
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum UserRole {
  OWNER
  CASHIER
  INVENTORY
  READONLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum QuoteStatus {
  DRAFT
  SENT
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum ReceiptType {
  TICKET
  INVOICE
}

model Tenant {
  id                String              @id @default(cuid())
  businessName      String
  email             String              @unique
  plan              String              @default("trial")
  trialEndsAt       DateTime?
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  users             User[]
  products          Product[]
  sales             Sale[]
  customers         Customer[]
  expenses          Expense[]
  cashMovements     CashMovement[]
  cashRegisterSessions CashRegisterSession[]
  debts             Debt[]
  debtPayments      DebtPayment[]
  categories        Category[]
  suppliers         Supplier[]
  services          Service[]
  promotions        Promotion[]
  inventoryMovements InventoryMovement[]
  storeSettings        StoreSettings?
  subscription         Subscription?
  onboardingCompleted  Boolean @default(false)
  quotes               Quote[]
  auditLogs            AuditLog[]
  arcaConfig           TenantARCAConfig?
  arcaTokenCache       ARCATokenCache?
  invoices             Invoice[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("")
  userCode  String?
  role      UserRole @default(OWNER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  auditLogs AuditLog[]

  @@unique([tenantId, userCode])
  @@index([tenantId])
}

model Product {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  name               String
  productCode        String?             @unique
  categoryName       String              @default("Otros")
  costPrice          Decimal             @db.Decimal(12, 2)
  salePrice          Decimal             @db.Decimal(12, 2)
  ivaRate            Float               @default(0.21)
  unit               String              @default("Unidad")
  stock              Int                 @default(0)
  minStock           Int                 @default(0)
  maxStock           Int?
  categoryId         String?
  subcategoryId      String?
  supplierId         String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  subcategory        Subcategory?        @relation(fields: [subcategoryId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  saleItems          SaleItem[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([tenantId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([supplierId])
}

model Sale {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  folio           Int              @default(0)
  receiptType     ReceiptType      @default(TICKET)
  receiptNumber   Int              @default(0)
  sellerCode      String?
  sellerId        String?
  cae             String?
  caeExpiry       DateTime?
  saleDate        DateTime         @default(now())
  paymentType     SalePaymentType  @default(CASH)
  customerId      String?
  debtId          String?          @unique
  totalAmount     Decimal          @db.Decimal(12, 2)
  discountAmount  Decimal          @default(0) @db.Decimal(10, 2)
  cashAmount      Decimal?         @db.Decimal(12, 2)
  paymentDetails  Json?
  customer        Customer?        @relation(fields: [customerId], references: [id])
  debt            Debt?            @relation(fields: [debtId], references: [id])
  items           SaleItem[]
  promotionUsages PromotionUsage[]
  returns         Return[]
  invoice         Invoice?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model SaleItem {
  id         String   @id @default(cuid())
  saleId     String
  productId  String?
  serviceId  String?
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  ivaRate    Float    @default(0.21)
  total      Decimal  @db.Decimal(12, 2)
  sale       Sale     @relation(fields: [saleId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
  service    Service? @relation(fields: [serviceId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([saleId])
  @@index([productId])
  @@index([serviceId])
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  expenseDate DateTime @default(now())
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  phone        String?
  email        String?
  customerCode String?  @unique
  segment      CustomerSegment @default(NINGUNO)
  debts        Debt[]
  sales        Sale[]
  quotes       Quote[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model Debt {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  customerId      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  remainingAmount Decimal       @db.Decimal(12, 2)
  dueDate         DateTime?
  writtenOff      Boolean       @default(false)
  writeOffNote    String?
  writeOffAt      DateTime?
  customer        Customer      @relation(fields: [customerId], references: [id])
  sale            Sale?
  payments        DebtPayment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([customerId])
}

model DebtPayment {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  debtId      String
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @default(now())
  debt        Debt     @relation(fields: [debtId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([debtId])
}

model CashMovement {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  movementDate DateTime @default(now())
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  source       String
  referenceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
  @@index([source, referenceId])
}

model Promotion {
  id                          String               @id @default(cuid())
  tenantId                    String
  tenant                      Tenant               @relation(fields: [tenantId], references: [id])
  name                        String
  code                        String?
  type                        PromotionType
  discountValue               Decimal              @db.Decimal(10, 2)
  application                 PromotionApplication
  categoryName                String?
  productAId                  String?
  productBId                  String?
  productBDiscount            Decimal?             @db.Decimal(10, 2)
  minimumAmount               Decimal?             @db.Decimal(10, 2)
  fixedPrice                  Decimal?             @db.Decimal(10, 2)
  activationType              PromotionActivation
  minimumPurchaseDiscountType String?              @default("PERCENTAGE")
  startsAt                    DateTime
  endsAt                      DateTime
  daysOfWeek                  String?
  maxUsages                   Int?
  maxUsagesPerCustomer        Int?
  customerSegment             CustomerSegment?
  isActive                    Boolean              @default(true)
  usages                      PromotionUsage[]
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  @@index([tenantId])
}

model PromotionUsage {
  id             String    @id @default(cuid())
  promotionId    String
  promotion      Promotion @relation(fields: [promotionId], references: [id])
  saleId         String?
  sale           Sale?     @relation(fields: [saleId], references: [id])
  customerId     String?
  discountAmount Decimal   @db.Decimal(10, 2)
  appliedAt      DateTime  @default(now())

  @@index([promotionId])
  @@index([saleId])
}

model CashRegisterSession {
  id               String             @id @default(cuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  status           CashRegisterStatus @default(OPEN)
  cashierName      String
  branchName       String             @default("Tienda Principal")
  shift            String?
  openedAt         DateTime           @default(now())
  closedAt         DateTime?
  openingAmount    Decimal            @db.Decimal(10, 2)
  closingAmount    Decimal?           @db.Decimal(10, 2)
  expectedAmount   Decimal?           @db.Decimal(10, 2)
  difference       Decimal?           @db.Decimal(10, 2)
  openingNotes     String?
  closingNotes     String?
  openingBreakdown Json?
  closingBreakdown Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([tenantId])
}

model InventoryMovement {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  productId      String
  movementDate   DateTime @default(now())
  reason         String
  previousStock  Int
  newStock       Int
  quantityChange Int
  product        Product  @relation(fields: [productId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
  @@index([productId])
}

model Category {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  subcategories Subcategory[]
  products      Product[]
  createdAt     DateTime      @default(now())

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Supplier {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  phone     String?
  email     String?
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Service {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  code        String     @unique
  name        String
  description String?
  price       Decimal    @db.Decimal(10, 2)
  isActive    Boolean    @default(true)
  saleItems   SaleItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
}

enum ReturnReasonCategory {
  DEFECTO
  ERROR_VENTA
  CAMBIO_OPINION
  OTRO
}

model Return {
  id             String               @id @default(cuid())
  saleId         String
  sale           Sale                 @relation(fields: [saleId], references: [id])
  items          ReturnItem[]
  totalAmount    Decimal              @db.Decimal(12, 2)
  reasonCategory ReturnReasonCategory @default(OTRO)
  reasonNote     String?
  createdAt      DateTime             @default(now())

  @@index([saleId])
}

model ReturnItem {
  id        String  @id @default(cuid())
  returnId  String
  return    Return  @relation(fields: [returnId], references: [id])
  productId String
  quantity  Int
  restock   Boolean @default(true)

  @@index([returnId])
}

model CodeCounter {
  id      String @id
  lastVal Int    @default(0)
}

model StoreSettings {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id])
  businessName         String   @default("SOLVEN")
  ownerName            String   @default("Propietario")
  phone                String   @default("")
  email                String   @default("")
  address              String   @default("")
  taxId                String   @default("")
  currency             String   @default("ARS")
  timezone             String   @default("America/Argentina/Buenos_Aires")
  dateFormat           String   @default("DD/MM/YYYY")
  language             String   @default("es")
  printerEnabled       Boolean  @default(false)
  soundsEnabled        Boolean  @default(true)
  darkMode             Boolean  @default(false)
  desktopNotifications Boolean  @default(false)
  arcaEnabled          Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String             @unique
  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  rebillSubscriptionId String?            @unique
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}


model Quote {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  quoteNumber     String      @unique
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  customerName    String      @default("")
  customerEmail   String      @default("")
  customerPhone   String      @default("")
  status          QuoteStatus @default(DRAFT)
  totalAmount     Decimal     @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  validUntil      DateTime
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  saleId          String?     @unique
  reminderSentAt  DateTime?
  items           QuoteItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@index([validUntil])
}

model QuoteItem {
  id         String  @id @default(cuid())
  quoteId    String
  quote      Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId  String?
  serviceId  String?
  name       String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)

  @@index([quoteId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  userCode   String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, action])
  @@index([tenantId, createdAt])
}

model TenantARCAConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  cuit                String
  puntoVenta          Int
  condicionIVA        String   // "RI" | "MONO"
  certEncrypted       String?  @db.Text
  privateKeyEncrypted String?  @db.Text
  ambiente            String   @default("homo") // "homo" | "prod"
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
}

model ARCATokenCache {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  token     String   @db.Text
  sign      String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String
  saleId        String?  @unique
  cae           String
  caeFchVto     String   // YYYYMMDD
  voucherNumber Int
  voucherType   Int      // 1=Factura A, 6=Factura B, 11=Factura C
  puntoVenta    Int
  docTipo       Int      // 80=CUIT, 96=DNI, 99=Consumidor Final
  docNro        String   // "0" para consumidor final
  impTotal      Decimal  @db.Decimal(12, 2)
  impNeto       Decimal  @db.Decimal(12, 2)
  impIVA        Decimal  @db.Decimal(12, 2)
  impOpEx       Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  sale          Sale?    @relation(fields: [saleId], references: [id])

  @@index([tenantId])
}
